BOT_PRIVATE_KEY=0x...
DEPOSIT_WALLET_ADDRESS=0x...
POLYGON_RPC_URL=https://polygon-rpc.com
USD_PER_TRADE=1
ENTRY_PRICE=0.33
ORDER_SIDE=UP
DB_PATH=
SCAN_INTERVAL_MS=5000
STOP_POLL_MS=1000
# Exit thresholds (best-bid based). Defaults shown; TAKE_PROFIT_PRICE must be > STOP_LOSS_PRICE.
STOP_LOSS_PRICE=0.15
TAKE_PROFIT_PRICE=0.98
KILL_SWITCH=false

# Analytics API (optional — run: npm run analytics)
ANALYTICS_HOST=
ANALYTICS_PORT=
# ANALYTICS_API_KEY=your-secret-token
# ANALYTICS_CORS_ORIGIN=*